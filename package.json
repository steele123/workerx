{
	"name": "workerx",
	"version": "0.0.0",
	"private": true,
	"scripts": {
		"check": "pnpm run typecheck && pnpm run format:check && wrangler deploy --dry-run --outdir .wrangler/dist",
		"deploy": "wrangler deploy",
		"dev": "wrangler dev",
		"format": "prettier --write .",
		"format:check": "prettier --check .",
		"typecheck": "wrangler types worker-configuration.d.ts --env-file .dev.vars.example --include-runtime=false --strict-vars=false --check && tsc --noEmit"
	},
	"devDependencies": {
		"@cloudflare/workers-types": "^5.20260717.1",
		"@types/mime-types": "^3.0.1",
		"prettier": "^3.9.5",
		"typescript": "^7.0.2",
		"wrangler": "^4.111.0"
	},
	"dependencies": {
		"hono": "^4.12.30",
		"isbot": "^5.2.1",
		"mime-types": "^3.0.2",
		"nanoid": "^6.0.0"
	}
}
