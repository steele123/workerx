{
  "Version": "16.1.0",
  "Name": "fs share.catlab.gg",
  "DestinationType": "TextUploader, FileUploader",
  "RequestMethod": "POST",
  "RequestURL": "https://share.catlab.gg/file",
  "Headers": {
    "Authorization": "YOUR_ACCESS_KEY"
  },
  "Body": "MultipartFormData",
  "FileFormName": "file",
  "URL": "{json:url}",
  "ThumbnailURL": "{json:url}",
  "DeletionURL": "{json:delete}",
  "ErrorMessage": "{json:error}"
}
