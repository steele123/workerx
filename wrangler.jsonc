{
	"$schema": "./node_modules/wrangler/config-schema.json",
	"name": "share",
	"main": "src/index.ts",
	"compatibility_date": "2026-07-16",
	"compatibility_flags": ["nodejs_compat"],
	"kv_namespaces": [
		{
			"binding": "KV",
			"id": "95188541f24a41ff9c53278da2ecf66d",
		},
	],
	"r2_buckets": [
		{
			"binding": "STORAGE",
			"bucket_name": "personal",
		},
	],
	"observability": {
		"enabled": true,
		"head_sampling_rate": 0.1,
	},
	"vars": {
		"SITE_URL": "https://share.catlab.gg",
	},
}
